model LessonDescription {
  id          String   @id @default(cuid())
  lessonId    String   @unique
  textContent String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
}

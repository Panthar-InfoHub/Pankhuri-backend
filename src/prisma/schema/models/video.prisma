model Video {
  id               String        @id @default(cuid())
  title            String
  thumbnailUrl     String?
  storageKey       String?
  playbackUrl      String?
  status           String
  duration         Int?
  metadata         Json?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  videoDescription Json?
  externalUrl      String?
  demoCourses      Course[]      @relation("DemoVideos")
  videoLessons     VideoLesson[]
}
